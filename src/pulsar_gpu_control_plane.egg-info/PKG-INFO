source venv/bin/activate
cd src && python -m pulsar.cli server

# 2. Submit jobs in another terminal
source venv/bin/activate
cd src && python -m pulsar.cli submit -u team-a -g 2
cd src && python -m pulsar.cli submit -u team-b -g 4

# 3. Monitor
cd src && python -m pulsar.cli cluster
cd src && python -m pulsar.cli fairness
cd src && python -m pulsar.cli jobs
```

